{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPlan": {
      "providers": {
        "node": true,
        "python": false
      },
      "phases": {
        "setup": {
          "nixPkgs": ["nodejs_20"]
        },
        "install": {
          "cmds": ["cd backend && npm install"]
        }
      },
      "start": {
        "cmd": "cd backend && node server.cjs"
      }
    }
  },
  "deploy": {
    "startCommand": "cd backend && node server.cjs",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
